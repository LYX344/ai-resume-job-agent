APP_NAME=AI Resume Job Agent
APP_ENV=development
APP_VERSION=0.1.0
API_PREFIX=/api/v1
LOG_LEVEL=INFO

# OpenAI-compatible chat model. This can point to a hosted provider or a local reverse proxy.
LLM_PROVIDER=openai-compatible
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=1

# Local reverse proxy example:
# LLM_PROVIDER=openai-compatible
# LLM_BASE_URL=http://127.0.0.1:12315/v1
# LLM_MODEL=your-model
# LLM_API_KEY=your-local-key

# Embedding defaults to fake so the project can run without API keys.
# Set EMBEDDING_PROVIDER=openai-compatible and fill the fields below to use a real embedding API.
EMBEDDING_PROVIDER=fake
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=
# Optional. Use 0 to omit the field. Qwen3 embedding models can use this to match REDIS_VECTOR_DIMENSION.
EMBEDDING_DIMENSIONS=0
EMBEDDING_TIMEOUT_SECONDS=30
EMBEDDING_MAX_RETRIES=1

# Optional rerank model. Keep `identity` for no-key local development.
RERANK_PROVIDER=identity
RERANK_BASE_URL=https://api.siliconflow.cn/v1
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_API_KEY=
RERANK_CANDIDATE_COUNT=20
RERANK_TIMEOUT_SECONDS=30

# Fill this later when we reach the Redis stage.
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_SOCKET_TIMEOUT_SECONDS=2

# Redis vector index defaults. We only prepare the config in stage 3;
# actual index creation happens in the document ingestion stage.
REDIS_VECTOR_INDEX_NAME=idx:docs
REDIS_VECTOR_KEY_PREFIX=doc:
REDIS_VECTOR_STORAGE_TYPE=HASH
REDIS_VECTOR_FIELD_NAME=embedding
REDIS_VECTOR_CONTENT_FIELD_NAME=content
REDIS_VECTOR_METADATA_FIELD_NAME=metadata
REDIS_VECTOR_DIMENSION=1536
REDIS_VECTOR_DATA_TYPE=FLOAT32
REDIS_VECTOR_ALGORITHM=HNSW
REDIS_VECTOR_DISTANCE_METRIC=COSINE

# RQ document indexing worker.
DOCUMENT_INDEX_QUEUE_NAME=document-index
DOCUMENT_INDEX_JOB_TIMEOUT_SECONDS=300
DOCUMENT_INDEX_RESULT_TTL_SECONDS=3600
DOCUMENT_INDEX_FAILURE_TTL_SECONDS=86400

# Agent checkpoint backend:
# - local_file: persists checkpoints to a local file for single-machine demos.
# - in_memory: process-local only, useful for tests/debugging.
AGENT_CHECKPOINT_BACKEND=local_file
AGENT_CHECKPOINT_PATH=data/checkpoints/agent_checkpoints.pkl

# MySQL defaults for the structured job-application QA stage.
# Docker Compose initializes this dev-only read-only user in docker/mysql/init/01_job_applications.sql.
MYSQL_URL=mysql+pymysql://agent_reader:agent_reader_password@127.0.0.1:3306/personal_agent
MYSQL_CONNECT_TIMEOUT_SECONDS=3
MYSQL_QUERY_TIMEOUT_SECONDS=5
MYSQL_ALLOWED_TABLES=["job_applications","application_events"]
MYSQL_DEFAULT_LIMIT=50
MYSQL_MAX_LIMIT=100

CORS_ALLOW_ORIGINS=["http://127.0.0.1:5173","http://localhost:5173"]

# PDF extraction and optional OCR for scanned pages.
PDF_OCR_ENABLED=true
PDF_OCR_PROVIDER=paddleocr
PDF_TEXT_LAYER_MIN_CHARS=20
PDF_OCR_DPI=200
PDF_OCR_LANGUAGE=ch
PDF_OCR_ENABLE_SEAL=true
PDF_OCR_MAX_PAGES=50
PDF_OCR_API_BASE_URL=
PDF_OCR_API_KEY=
PDF_OCR_API_MODEL=paddleocr-vl
PDF_OCR_TIMEOUT_SECONDS=60

# Local trace store. This is demo/debug observability, not a production APM.
TRACE_ENABLED=true
TRACE_PATH=data/traces/traces.jsonl
TRACE_MAX_RECENT=100

# Query rewrite before retrieval. Uses the active LLM and falls back to original query.
QUERY_REWRITE_PROVIDER=llm
QUERY_REWRITE_MAX_TOKENS=120

# MCP (Model Context Protocol) client.
# Disabled by default. When enabled, the agent connects to the MCP servers
# defined in MCP_CONFIG_PATH and exposes their tools to the LLM.
# The config file uses the de-facto `mcpServers` shape (see data/mcp/servers.example.json).
MCP_ENABLED=false
MCP_CONFIG_PATH=data/mcp/servers.json
MCP_TOOL_TIMEOUT_SECONDS=30
MCP_MAX_TOOLS=32
